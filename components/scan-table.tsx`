const UI = {
  getPctClass(value: number): "pos" | "neg" | "neutral" {
    if (value > 0) return "pos";
    if (value < 0) return "neg";
    return "neutral";
  },

  getDecisionClass(value: Decision): "allow" | "watch" | "block" {
    if (value === "ALLOW") return "allow";
    if (value === "BLOCK") return "block";
    return "watch";
  },

  getDecisionRank(value: Decision): number {
    if (value === "ALLOW") return 3;
    if (value === "WATCH") return 2;
    return 1;
  },

  getRegimeClass(value: Regime): "regimeStable" | "regimeTransition" | "regimeVolatile" {
    if (value === "STABLE") return "regimeStable";
    if (value === "TRANSITION") return "regimeTransition";
    return "regimeVolatile";
  },

  getStabilityLabel(stability: number): "LOW" | "MEDIUM" | "HIGH" {
    if (stability >= 70) return "HIGH";
    if (stability >= 40) return "MEDIUM";
    return "LOW";
  },

  getTradeButtonClass(disabled: boolean): string {
    return disabled ? "tradeDisabled" : "tradeBtn";
  },
} as const;

