function getSortValue(asset: NormalizedAsset, preset: SortPreset): number {
  switch (preset) {
    case "price_desc":
    case "price_asc":
      return asset.price;

    case "pct24h_desc":
    case "pct24h_asc":
      return asset.pct24h;

    case "chart7d_desc":
    case "chart7d_asc":
      return asset.pct7dDerived;

    case "stability_desc":
    case "stability_asc":
      return asset.stability;

    case "opportunity_desc":
    case "opportunity_asc":
      return asset.opportunity;

    case "decision_desc":
    case "decision_asc":
      return UI.getDecisionRank(asset.decision);

    default:
      return asset.opportunity;
  }
}


function compareTopOpportunities(left: NormalizedAsset, right: NormalizedAsset): number {
  if (right.opportunity !== left.opportunity) {
    return right.opportunity - left.opportunity;
  }

  if (UI.getDecisionRank(right.decision) !== UI.getDecisionRank(left.decision)) {
    return UI.getDecisionRank(right.decision) - UI.getDecisionRank(left.decision);
  }

  if (right.stability !== left.stability) {
    return right.stability - left.stability;
  }

  const leftRank = left.rank ?? Number.POSITIVE_INFINITY;
  const rightRank = right.rank ?? Number.POSITIVE_INFINITY;

  if (leftRank !== rightRank) {
    return leftRank - rightRank;
  }

  return left.symbol.localeCompare(right.symbol);
}

/* ==========================================================================
   6. FORMATTERS
   ========================================================================== */

function formatPrice(value: number, quote: Quote): string {
  if (!Number.isFinite(value)) return "-";

  if (quote === "EUR") {
    return new Intl.NumberFormat("fr-FR", {
      style: "currency",
      currency: "EUR",
      maximumFractionDigits: value >= 1000 ? 0 : value >= 1 ? 2 : 6,
    }).format(value);
  }

  if (quote === "USD") {
    return new Intl.NumberFormat("en-US", {
      style: "currency",
      currency: "USD",
      maximumFractionDigits: value >= 1000 ? 0 : value >= 1 ? 2 : 6,
    }).format(value);
  }

  const decimals = value >= 1000 ? 0 : value >= 1 ? 2 : 6;

  return `${value.toLocaleString("en-US", {
    minimumFractionDigits: 0,
    maximumFractionDigits: decimals,
  })} ${quote}`;
}

function formatPct(value: number): string {
  if (!Number.isFinite(value)) return "-";
  return `${value > 0 ? "+" : ""}${value.toFixed(2)}%`;
}

function formatVolatility(value: number): string {
  if (!Number.isFinite(value)) return "-";
  return `${value.toFixed(2)}%`;
}

/* ==========================================================================
   7. SPARKLINE
   ========================================================================== */

function buildSparklinePath(
  points: number[],
  width: number,
  height: number,
  paddingX = 4,
  paddingY = 3,
): string {
  if (points.length < 2) return "";

  const base = points[0] || 1;
  const normalized = points.map((value) => ((value - base) / base) * 100);

  const min = Math.min(...normalized);
  const max = Math.max(...normalized);
  const range = max - min || 1;

  const drawWidth = Math.max(width - paddingX * 2, 1);
  const drawHeight = Math.max(height - paddingY * 2, 1);

  return normalized
    .map((value, index) => {
      const x = paddingX + (index / Math.max(normalized.length - 1, 1)) * drawWidth;
      const y = paddingY + ((max - value) / range) * drawHeight;
      return `${index === 0 ? "M" : "L"} ${x.toFixed(2)} ${y.toFixed(2)}`;
    })
    .join(" ");
}

function resolveChartTone(data: number[] | null, pct24h: number): "up" | "down" | "flat" {
  if (data && data.length > 1) {
    const first = data[0];
    const last = data[data.length - 1];

    if (last > first) return "up";
    if (last < first) return "down";
  }

  if (pct24h > 0) return "up";
  if (pct24h < 0) return "down";
  return "flat";
}

function ChartCell({
  data,
  pct24h,
}: {
  data: number[] | null;
  pct24h: number;
}) {
  if (!data || data.length < 2) {
    return <div className="sparkCell sparkFallback">—</div>;
  }

  const width = 130;
  const height = 40;
  const path = buildSparklinePath(data, width, height);
  const tone = resolveChartTone(data, pct24h);
  const toneClass =
    tone === "up" ? "sparkUp" : tone === "down" ? "sparkDown" : "sparkFlat";

  return (
    <div className="sparkCell" aria-label="7 day chart">
      <svg
        className={`sparkSvg ${toneClass}`}
        width={width}
        height={height}
        viewBox={`0 0 ${width} ${height}`}
        preserveAspectRatio="none"
        role="img"
        aria-hidden="true"
      >
        <path d={path} className="sparkPath" />
      </svg>
    </div>
  );
}

/* ==========================================================================
   8. SHARED MODULES
   ========================================================================== */

function passes7dPatternFilter(asset: NormalizedAsset): boolean {
  const prices = asset.chart7d;

  if (!Array.isArray(prices) || prices.length < 12) {
    return false;
  }

  let directionChanges = 0;
  let previousDirection = 0;
  let significantMoves = 0;

  for (let i = 1; i < prices.length; i++) {
    const prev = prices[i - 1];
    const current = prices[i];

    if (!Number.isFinite(prev) || !Number.isFinite(current) || prev <= 0) {
      return false;
    }

    const pct = ((current - prev) / prev) * 100;

    // bruit ignoré
    if (Math.abs(pct) < 0.35) {
      continue;
    }

    significantMoves++;

    const direction = pct > 0 ? 1 : -1;

    if (previousDirection !== 0 && direction !== previousDirection) {
      directionChanges++;
    }

    previousDirection = direction;
  }

  if (significantMoves < 4) {
    return false;
  }

  const instabilityRate = directionChanges / significantMoves;

  return instabilityRate <= 0.55;
}


function getTopOpportunitiesFromVisibleData(
  data: NormalizedAsset[],
): NormalizedAsset[] {
  return [...data]
    .sort((a, b) => {
      const aDecision = UI.getDecisionRank(a.decision);
      const bDecision = UI.getDecisionRank(b.decision);

      const aRank =
        typeof a.rank === "number" && Number.isFinite(a.rank)
          ? a.rank
          : Number.POSITIVE_INFINITY;

      const bRank =
        typeof b.rank === "number" && Number.isFinite(b.rank)
          ? b.rank
          : Number.POSITIVE_INFINITY;

      const aScore =
        aDecision * 100000 +
        a.opportunity * 1000 +
        a.stability * 100 -
        Math.min(aRank, 999999);

      const bScore =
        bDecision * 100000 +
        b.opportunity * 1000 +
        b.stability * 100 -
        Math.min(bRank, 999999);

      if (aScore !== bScore) {
  return bScore - aScore;
}

if (a.stability !== b.stability) {
  return b.stability - a.stability;
}

if (aRank !== bRank) {
  return aRank - bRank;
}   

      return a.symbol.localeCompare(b.symbol);
    })
    .slice(0, 3);
}

