/* ==========================================================================
   3. SAFE HELPERS
   ========================================================================== */

function safeString(value: unknown, fallback = ""): string {
  return typeof value === "string" && value.trim().length > 0 ? value.trim() : fallback;
}

function safeNumber(value: unknown, fallback = 0): number {
  return typeof value === "number" && Number.isFinite(value) ? value : fallback;
}

function safeNullableNumber(value: unknown): number | null {
  return typeof value === "number" && Number.isFinite(value) ? value : null;
}

function safeArrayNumbers(value: unknown): number[] | null {
  if (!Array.isArray(value)) return null;

  const numbers = value.filter(
    (item): item is number => typeof item === "number" && Number.isFinite(item),
  );

  return numbers.length >= 2 ? numbers : null;
}

function isAssetsArray(value: unknown): value is ScanAssetInput[] {
  return Array.isArray(value);
}

function clampScore(value: unknown): number {
  const numeric = safeNumber(value, 0);
  return Math.max(0, Math.min(100, Math.round(numeric)));
}

function buildFallbackLogo(symbol: string): string {
  return symbol.slice(0, 1).toUpperCase() || "?";
}

function compute7dFromChart(points: number[] | null): number | null {
  if (!points || points.length < 2) return null;

  const first = points[0];
  const last = points[points.length - 1];

  if (!Number.isFinite(first) || !Number.isFinite(last) || first === 0) return null;

  return ((last - first) / Math.abs(first)) * 100;
}

function compute7dVolatility(points: number[] | null): number | null {
  if (!points || points.length < 3) return null;

  const returns: number[] = [];

  for (let index = 1; index < points.length; index += 1) {
    const previous = points[index - 1];
    const current = points[index];

    if (!Number.isFinite(previous) || !Number.isFinite(current) || previous === 0) {
      continue;
    }

    returns.push(((current - previous) / previous) * 100);
  }

  if (returns.length < 2) return null;

  const mean = returns.reduce((sum, value) => sum + value, 0) / returns.length;
  const variance =
    returns.reduce((sum, value) => sum + (value - mean) ** 2, 0) / returns.length;

  return Math.sqrt(variance);
}

/* ==========================================================================
   4. NORMALIZATION
   ========================================================================== */

function normalizeQuote(value?: string): Quote {
  const normalized = safeString(value, "EUR").toUpperCase();

  if (normalized === "USD") return "USD";
  if (normalized === "USDT") return "USDT";
  return "EUR";
}

function normalizeLimit(value: number | undefined, fallback: number): number {
  if (typeof value !== "number" || !Number.isFinite(value)) return fallback;
  return Math.max(1, Math.floor(value));
}

function normalizeRegime(value: unknown): Regime {
  const normalized = safeString(value, "TRANSITION").toUpperCase();

  if (normalized === "STABLE") return "STABLE";
  if (normalized === "VOLATILE") return "VOLATILE";
  return "TRANSITION";
}

function normalizeDecision(value: unknown): Decision {
  const normalized = safeString(value, "WATCH").toUpperCase();

  if (normalized === "ALLOW") return "ALLOW";
  if (normalized === "BLOCK") return "BLOCK";
  return "WATCH";
}

function normalizeSortPreset(value?: string): SortPreset {
  switch (safeString(value, "opportunity_desc")) {
    case "price_desc":
    case "price_asc":
    case "pct24h_desc":
    case "pct24h_asc":
    case "chart7d_desc":
    case "chart7d_asc":
    case "stability_desc":
    case "stability_asc":
    case "opportunity_desc":
    case "opportunity_asc":
    case "decision_desc":
    case "decision_asc":
      return value as SortPreset;
    default:
      return "opportunity_desc";
  }
}

function normalizeChart(value: unknown): number[] | null {
  const data = safeArrayNumbers(value);
  if (!data) return null;

  return data.slice(-40);
}

function normalizeAsset(input: ScanAssetInput): NormalizedAsset {
  const symbol = safeString(input.symbol, "UNKNOWN").toUpperCase();
  const name = safeString(input.name, symbol);

  const chart7d =
    normalizeChart(input.chart7d) ??
    normalizeChart(input.sparkline_7d) ??
    normalizeChart(input.sparkline);

  const pct7dDerived =
    safeNullableNumber(input.pct7dDerived) ??
    safeNullableNumber(input.chg_7d_pct) ??
    compute7dFromChart(chart7d) ??
    0;

  const volatility7d = compute7dVolatility(chart7d) ?? 0;

  return {
    key: safeString(input.id, symbol),
    id: safeString(input.id, symbol),

    rank: safeNullableNumber(input.rank),

    symbol,
    name,

    price: safeNumber(input.price, 0),
    pct24h: safeNumber(input.pct24h ?? input.chg_24h_pct, 0),
    pct7dDerived: safeNumber(pct7dDerived, 0),
    volatility7d: safeNumber(volatility7d, 0),

    stability: clampScore(input.stability ?? input.stability_score),
    opportunity: clampScore(input.opportunity ?? input.opportunity_score),

    regime: normalizeRegime(input.regime),
    decision: normalizeDecision(input.decision),

    chart7d,

    logoUrl:
      safeString(input.logoUrl) ||
      safeString(input.logo_url) ||
      safeString(input.image) ||
      null,

    fallbackLogo: safeString(input.fallbackLogo, buildFallbackLogo(symbol)),

    href:
      safeString(input.href) ||
      safeString(input.affiliate_url) ||
      safeString(input.binance_url) ||
      null,

    rating: safeString(input.rating) || null,
  };
}

/* ==========================================================================
   5. SORTING CORE
