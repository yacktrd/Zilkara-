export default function ScanTable({
  assets,
  quote = "EUR",
  sort,
  limit,
}: Props) {
  const [query, setQuery] = useState("");
  const [sortPreset, setSortPreset] = useState<SortPreset>(normalizeSortPreset(sort));

  const deferredQuery = useDeferredValue(query);
  const normalizedQuote = normalizeQuote(quote);

  const assetsMissing = assets == null;
  const assetsInvalid = !assetsMissing && !isAssetsArray(assets);
  const sourceAssets = isAssetsArray(assets) ? assets : null;

  if (assetsMissing) {
      <section className="topOpportunitiesCompact">  <section className="topOpportunitiesCompact">return (
      <StateBlock
        title="Data source unavailable."
        message="The assets source is missing or not ready yet."
      />
    );
  }

  if (assetsInvalid || sourceAssets === null) {
    return (
      <StateBlock
        title="Invalid assets payload."
        message="The upstream contract did not return a valid assets array."
      />
    );
  }

  if (sourceAssets.length === 0) {
    return (
      <StateBlock
        title="No assets available."
        message="The source returned a valid array, but the current universe is empty."
      />
    );
  }

  const normalizedLimit =
    typeof limit === "number" && Number.isFinite(limit)
      ? normalizeLimit(limit, sourceAssets.length)
      : sourceAssets.length;

    const visibleData = useMemo(() => {
  const normalizedQuery = deferredQuery.trim().toLowerCase();
  const normalizedAssets = sourceAssets.map(normalizeAsset);



  const sortedAssets = [...normalizedAssets].sort((a, b) => {
  const aPrice = Number.isFinite(a.price) ? a.price : 0;
  const bPrice = Number.isFinite(b.price) ? b.price : 0;

  if (aPrice !== bPrice) {
    return bPrice - aPrice;
  }

  return a.symbol.localeCompare(b.symbol);
});

  console.log("PROPS LIMIT:", limit);
  console.log("LIMIT DEBUG:", limit, normalizedLimit, sourceAssets.length);

  return sortedAssets.slice(0, normalizedLimit);
},[sourceAssets, deferredQuery, normalizedLimit, sortPreset]);


  return (
    <section className="section">
      <div className="tableHeader">
        <a href="/" className="brandLink" aria-label="Go to home">
          <div className="titleBlock">
            <h2 className="productTitle">Xyvala</h2>
          </div>
        </a>

        <div className="headerCenter">
          <ToolbarModule
            query={query}
            setQuery={setQuery}
            sort={sortPreset}
            setSort={setSortPreset}
          />
        </div>
      </div>

      <TopOpportunitiesCompact data={visibleData} quote={normalizedQuote} />

           <DesktopTable data={topData}  <div className="desktopOnly">
        <DesktopTable data={visibleData} quote={normalizedQuote} />
      </div>

      <div className="mobileOnly">
        <MobileCards data={visibleData} quote={normalizedQuote} />
      </div>
    </section>
  );
}
